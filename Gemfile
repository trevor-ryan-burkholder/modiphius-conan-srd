source "https://rubygems.org"

# Use the github-pages gem so what we build locally matches what GitHub Pages will build.
gem "github-pages", group: :jekyll_plugins

# Plugins listed here must also be referenced in _config.yml.
group :jekyll_plugins do
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end

# Windows / JRuby support
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw, :mswin]

# Required for newer Rubies
gem "webrick", "~> 1.8"
